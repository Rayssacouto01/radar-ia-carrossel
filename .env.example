# Claude / Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Quantas noticias processar por execucao (recomendado: 1)
MAX_NEWS=1

# Evolution API (WhatsApp)
EVOLUTION_URL=https://sua-evolution.com
EVOLUTION_API_KEY=sua-api-key
EVOLUTION_INSTANCE=nome-da-instancia
WHATSAPP_NUMBER=5567999999999

# Interface web (geração manual por link)
WEBAPP_PASSWORD=defina-uma-senha-forte
FLASK_SECRET_KEY=defina-uma-chave-aleatoria-longa

# Opcional: cookies.txt exportado de um navegador logado no YouTube.
# Necessário se o download de link do YouTube levar bloqueio anti-bot no servidor.
# Ver https://github.com/yt-dlp/yt-dlp/wiki/FAQ#how-do-i-pass-cookies-to-yt-dlp
YOUTUBE_COOKIES_FILE=
